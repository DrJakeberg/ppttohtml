    "pdfjs-dist": "^4.7.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "supertest": "^7.1.1",
    "vitest": "^2.1.8"
  }
}
