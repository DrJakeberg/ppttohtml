{
  "name": "ppttohtml",
  "version": "1.0.0",
  "description": "Self-hosted presentation kiosk with admin upload and autoplay",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development node --watch src/server.js",
